6\u89c9\u66f4\u4e3a\u548c\u8c10, \u4f46\u6a21\u7cca\u8fb9\u7ebf\u5bf9\u5904\u7406\u56fe\u7247\u9020\u6210\u56f0\u6270.","title":"\u900f\u660e\u622a\u56fe"},{"location":"0056AlphaCrop/#_2","text":"\u5bfc\u51fa\u900f\u660e\u80cc\u666f\u56fe, \u6700\u597d\u7531\u8f6f\u4ef6\u751f\u6210","title":"\u5b8c\u7f8e\u65b9\u5f0f"},{"location":"0056AlphaCrop/#easyicon","text":"EasyIcon \u91c7\u7528\u504f\u8272\u7684\u65b9\u5f0f, \u7c7b\u4f3c\u65e9\u671f\u7684 PS \u9b54\u672f\u5957\u5de5\u5177, \u8fd9\u79cd\u65b9\u5f0f\u5f88\u4e0d\u5b8c\u7f8e \u7a0b\u5e8f\u4e0a\u8fdb\u4e00\u6b65\u5904\u7406, \u9700\u8981\u7b97\u6cd5\u4e0e\u7814\u7a76, \u6682\u65f6\u653e\u5f03 \u5148\u5c06\u5c31\u4f7f\u7528","title":"EasyIcon \u7684\u65b9\u5f0f"},{"location":"0057UploadImage/","text":"\u4e0a\u4f20\u56fe\u5f62","title":"\u4e0a\u4f20\u56fe\u5f62"},{"location":"0057UploadImage/#_1","text":"","title":"\u4e0a\u4f20\u56fe\u5f62"},{"location":"0059Appendix/","text":"\u5176\u4ed6\u529f\u80fd \u53d6\u8272 Ctrl + LClick on client area. Jul 03, 2021 \u62d6\u62fd (Drag and drop) \u652f\u6301\u62d6\u5165 png, jpeg, jpg, bmp. Jul 22, 2021","title":"\u5176\u4ed6\u529f\u80fd"},{"location":"0059Appendix/#_1","text":"","title":"\u5176\u4ed6\u529f\u80fd"},{"location":"0059Appendix/#_2","text":"Ctrl + LClick on client area. Jul 03, 2021","title":"\u53d6\u8272"},{"location":"0059Appendix/#drag-and-drop","text":"\u652f\u6301\u62d6\u5165 png, jpeg, jpg, bmp. Jul 22, 2021","title":"\u62d6\u62fd (Drag and drop)"},{"location":"0061CaseCropDesktop/","text":"\u7528\u4f8b\u4e00 \u914d\u5408 Print Screen, \u5168\u5c4f\u622a\u53d6 \u952e\u76d8 Print Screen Ctrl + V \u590d\u5236\u8fdb\u6765 \u5bfc\u51fa","title":"\u7528\u4f8b\u4e00"},{"location":"0061CaseCropDesktop/#_1","text":"\u914d\u5408 Print Screen, \u5168\u5c4f\u622a\u53d6 \u952e\u76d8 Print Screen Ctrl + V \u590d\u5236\u8fdb\u6765 \u5bfc\u51fa","title":"\u7528\u4f8b\u4e00"},{"location":"0062CaseAccompanyPaint/","text":"\u7528\u4f8b\u4e8c \u914d\u5408 MS Paint \u4efb\u610f\u88c1\u526a, Paint3D \u4e5f\u80fd\u5b9e\u73b0 EasyIcon \u91cc\u9700\u8981\u5148\u8c03\u6846, \u4ee5\u6846\u6765\u88c1\u526a\u56fe\u7247, \u8fd9\u4e00\u70b9\u4e0a\u4e0d\u5982 MS Paint \u7075\u6d3b \u4e00\u5f20 512 * 512 \u56fe\u7247 \u7f16\u8f91\u56fe\u7247 Ctrl + A \u5168\u9009 Shilf \u62d6\u52a8\u9f20\u6807 Ctrl + S \u4fdd\u5b58 \u5bfc\u51fa","title":"\u7528\u4f8b\u4e8c"},{"location":"0062CaseAccompanyPaint/#_1","text":"\u914d\u5408 MS Paint \u4efb\u610f\u88c1\u526a, Paint3D \u4e5f\u80fd\u5b9e\u73b0 EasyIcon \u91cc\u9700\u8981\u5148\u8c03\u6846, \u4ee5\u6846\u6765\u88c1\u526a\u56fe\u7247, \u8fd9\u4e00\u70b9\u4e0a\u4e0d\u5982 MS Paint \u7075\u6d3b \u4e00\u5f20 512 * 512 \u56fe\u7247 \u7f16\u8f91\u56fe\u7247 Ctrl + A \u5168\u9009 Shilf \u62d6\u52a8\u9f20\u6807 Ctrl + S \u4fdd\u5b58 \u5bfc\u51fa","title":"\u7528\u4f8b\u4e8c"},{"location":"0100Knowledges/","text":"\u65e0\u635f PNG \u662f\u65e0\u635f\u538b\u7f29, JPEG \u662f\u6709\u635f\u538b\u7f29 JPEG \u4f18\u70b9\u662f\u5360\u7a7a\u95f4\u5f88\u5c0f. \u5931\u771f \u56fe\u7247\u4e3b\u8981\u6709\u4e24\u79cd\u7c7b\u578b, \u4f4d\u56fe\u548c\u77e2\u91cf\u56fe, \u5404\u6709\u5404\u7684\u4f18\u70b9. \u76f8\u8f83\u4e8e\u77e2\u91cf\u56fe\u53ef\u4ee5\u4efb\u610f\u7f29\u653e, \u4f4d\u56fe\u7f29\u653e\u4f1a\u5bfc\u81f4\u5931\u771f. \u4f4d\u56fe\u7531\u4e00\u7cfb\u5217\u7684\u70b9 (Pixel) \u8868\u793a, \u4ee5\u7535\u8111\u663e\u793a\u5668\u4e3e\u4f8b\u6765\u8bf4, \u8089\u773c\u89c2\u5bdf\u5c4f\u5e55\u6709\u65f6\u4f1a\u6709\u9897\u7c92\u611f, \u70b9\u5c31\u662f\u5c4f\u5e55\u4e0a\u7684\u70b9. \u5206\u8fa8\u7387 1920 * 1080 \u5c31\u4ee3\u8868\u6a2a\u5411\u6709 1920 \u4e2a\u70b9, \u7ad6\u5411\u6709 1080 \u4e2a\u70b9, \u8fd9\u4e9b\u70b9\u7ec4\u6210\u5c4f\u5e55\u56fe\u5f62, \u624b\u673a\u5c4f\u5e55\u540c\u7406. \u7f29\u5c0f\u4f4d\u56fe\u65f6, \u6bd4\u5982 512 * 512 \u7f29\u5c0f\u5230 256 * 256, \u7f29\u5c0f\u540e\u70b9\u96c6\u51cf\u5c11, \u6570\u636e\u4e22\u5931, \u65e0\u6cd5\u8fd8\u539f\u5230\u539f\u56fe, \u9020\u6210\u5931\u771f. \u653e\u5927\u4f4d\u56fe\u65f6, \u6bd4\u5982 3 * 3 \u5230 4 * 4, \u6a2a\u5411 4 \u4e2a\u70b9\u65e0\u6cd5\u56de\u5230 3 \u4e2a\u70b9, \u4e5f\u4f1a\u9020\u6210\u5931\u771f. \u5982\u679c\u662f 3 * 3 \u5230 6 * 6 \u4fbf\u4e0d\u4f1a\u5931\u771f, \u5982\u679c\u540c\u7528\u4e00\u79cd\u7b97\u6cd5, 4 * 4 \u4e5f\u80fd\u591f\u56de\u5230 3 * 3. \u8865\u507f\u529e\u6cd5 \u6297\u952f\u9f7f \u8bf4\u660e \u8fd9\u91cc\u53ea\u505a\u6d45\u8981\u63cf\u8ff0, \u53ef\u4ee5\u4f7f\u7528\u641c\u7d22\u5f15\u64ce\u7d22\u5f15\u5173\u952e\u5b57\u8fdb\u4e00\u6b65\u7406\u89e3 \u4f4d\u56fe (Raster graphics) \u77e2\u91cf\u56fe (Vector graphics) \u4f4d\u56fe\u5931\u771f \u6297\u952f\u9f7f PNG JPEG","title":"\u65e0\u635f"},{"location":"0100Knowledges/#_1","text":"PNG \u662f\u65e0\u635f\u538b\u7f29, JPEG \u662f\u6709\u635f\u538b\u7f29 JPEG \u4f18\u70b9\u662f\u5360\u7a7a\u95f4\u5f88\u5c0f.","title":"\u65e0\u635f"},{"location":"0100Knowledges/#_2","text":"\u56fe\u7247\u4e3b\u8981\u6709\u4e24\u79cd\u7c7b\u578b, \u4f4d\u56fe\u548c\u77e2\u91cf\u56fe, \u5404\u6709\u5404\u7684\u4f18\u70b9. \u76f8\u8f83\u4e8e\u77e2\u91cf\u56fe\u53ef\u4ee5\u4efb\u610f\u7f29\u653e, \u4f4d\u56fe\u7f29\u653e\u4f1a\u5bfc\u81f4\u5931\u771f. \u4f4d\u56fe\u7531\u4e00\u7cfb\u5217\u7684\u70b9 (Pixel) \u8868\u793a, \u4ee5\u7535\u8111\u663e\u793a\u5668\u4e3e\u4f8b\u6765\u8bf4, \u8089\u773c\u89c2\u5bdf\u5c4f\u5e55\u6709\u65f6\u4f1a\u6709\u9897\u7c92\u611f, \u70b9\u5c31\u662f\u5c4f\u5e55\u4e0a\u7684\u70b9. \u5206\u8fa8\u7387 1920 * 1080 \u5c31\u4ee3\u8868\u6a2a\u5411\u6709 1920 \u4e2a\u70b9, \u7ad6\u5411\u6709 1080 \u4e2a\u70b9, \u8fd9\u4e9b\u70b9\u7ec4\u6210\u5c4f\u5e55\u56fe\u5f62, \u624b\u673a\u5c4f\u5e55\u540c\u7406. \u7f29\u5c0f\u4f4d\u56fe\u65f6, \u6bd4\u5982 512 * 512 \u7f29\u5c0f\u5230 256 * 256, \u7f29\u5c0f\u540e\u70b9\u96c6\u51cf\u5c11, \u6570\u636e\u4e22\u5931, \u65e0\u6cd5\u8fd8\u539f\u5230\u539f\u56fe, \u9020\u6210\u5931\u771f. \u653e\u5927\u4f4d\u56fe\u65f6, \u6bd4\u5982 3 * 3 \u5230 4 * 4, \u6a2a\u5411 4 \u4e2a\u70b9\u65e0\u6cd5\u56de\u5230 3 \u4e2a\u70b9, \u4e5f\u4f1a\u9020\u6210\u5931\u771f. \u5982\u679c\u662f 3 * 3 \u5230 6 * 6 \u4fbf\u4e0d\u4f1a\u5931\u771f, \u5982\u679c\u540c\u7528\u4e00\u79cd\u7b97\u6cd5, 4 * 4 \u4e5f\u80fd\u591f\u56de\u5230 3 * 3.","title":"\u5931\u771f"},{"location":"0100Knowledges/#_3","text":"\u6297\u952f\u9f7f","title":"\u8865\u507f\u529e\u6cd5"},{"location":"0100Knowledges/#_4","text":"\u8fd9\u91cc\u53ea\u505a\u6d45\u8981\u63cf\u8ff0, \u53ef\u4ee5\u4f7f\u7528\u641c\u7d22\u5f15\u64ce\u7d22\u5f15\u5173\u952e\u5b57\u8fdb\u4e00\u6b65\u7406\u89e3 \u4f4d\u56fe (Raster graphics) \u77e2\u91cf\u56fe (Vector graphics) \u4f4d\u56fe\u5931\u771f \u6297\u952f\u9f7f PNG JPEG","title":"\u8bf4\u660e"},{"location":"0101DPI/","text":"DPI Windows \u7f29\u653e EasyIcon \u9002\u914d 1 - 1.5 \u500d\u7684\u7f29\u653e, \u6700\u9002\u6bd4\u4f8b 1.25 \u500d","title":"DPI Windows \u7f29\u653e"},{"location":"0101DPI/#dpi-windows","text":"EasyIcon \u9002\u914d 1 - 1.5 \u500d\u7684\u7f29\u653e, \u6700\u9002\u6bd4\u4f8b 1.25 \u500d","title":"DPI Windows \u7f29\u653e"},{"location":"0102Dimension/","text":"\u5e38\u7528\u56fe\u6807\u5c3a\u5bf8 16 * 16 \u7f51\u9875 favicon\uff0c\u7f51\u9875\u56fe\u6807","title":"\u5e38\u7528\u56fe\u6807\u5c3a\u5bf8"},{"location":"0102Dimension/#_1","text":"16 * 16 \u7f51\u9875 favicon\uff0c\u7f51\u9875\u56fe\u6807","title":"\u5e38\u7528\u56fe\u6807\u5c3a\u5bf8"},{"location":"EnglishDoc/0010index/","text":"Welcome to EasyIcon Doc","title":"Welcome to EasyIcon Doc"},{"location":"EnglishDoc/0010index/#welcome-to-easyicon-doc","text":"","title":"Welcome to EasyIcon Doc"}]}