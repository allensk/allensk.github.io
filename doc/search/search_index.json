f0c\u8bf7\u4fdd\u8bc1\u4e0d\u80fd\u66f4\u6362\u4fdd\u5b58\u8def\u5f84\uff0c\u5982\u679c\u66f4\u6362\u8def\u5f84 EasyIcon \u4e0d\u4f1a\u66f4\u65b0\u4fdd\u5b58\u7684\u56fe \u2713 \u4f7f\u7528 MS Paint, \u4efb\u610f\u7f16\u8f91\u5747\u53ef\u66f4\u65b0 \u2713 \u7b80\u5355\u6d82\u6539 MS Paint3D\uff0c\u53ef\u4ee5\u66f4\u65b0 \u2718 MS Paint3D \u63d0\u793a\u53e6\u5b58\u4e3a\u65f6 \u2718 \u6bd4\u5982\u64cd\u4f5c MS Paint3D \u6253\u5f00\u900f\u660e\u80cc\u666f\u65f6\uff0c\u4f1a\u63d0\u793a\u53e6\u5b58\u4e3a, \u8fd9\u4e2a\u60c5\u51b5 EasyIcon \u4e0d\u4f1a\u66f4\u65b0 \u5185\u7f6e\u7f16\u8f91 \u67e5\u770b \u88c1\u526a \u7f29\u653e \u900f\u660e","title":"\u7f16\u8f91"},{"location":"0051ImageEdit/#_1","text":"","title":"\u7f16\u8f91"},{"location":"0051ImageEdit/#_2","text":"MS Paint Windows \u753b\u56fe MS Paint3D Windows 3D \u753b\u56fe \u7528\u5916\u7f6e\u56fe\u5f62\u7f16\u8f91\u5668\u7f16\u8f91\u540e\u8bf7 \u4fdd\u5b58\u56fe\u5f62 Ctrl + S \u5e76\u5173\u95ed\u5916\u7f6e\u5916\u7f6e\u56fe\u5f62\u7f16\u8f91\u5668 \u8bd5\u7528\u5916\u7f6e\u56fe\u5f62\u7f16\u8f91\u5668\uff0c\u8bf7\u4fdd\u8bc1\u4e0d\u80fd\u66f4\u6362\u4fdd\u5b58\u8def\u5f84\uff0c\u5982\u679c\u66f4\u6362\u8def\u5f84 EasyIcon \u4e0d\u4f1a\u66f4\u65b0\u4fdd\u5b58\u7684\u56fe \u2713 \u4f7f\u7528 MS Paint, \u4efb\u610f\u7f16\u8f91\u5747\u53ef\u66f4\u65b0 \u2713 \u7b80\u5355\u6d82\u6539 MS Paint3D\uff0c\u53ef\u4ee5\u66f4\u65b0 \u2718 MS Paint3D \u63d0\u793a\u53e6\u5b58\u4e3a\u65f6 \u2718 \u6bd4\u5982\u64cd\u4f5c MS Paint3D \u6253\u5f00\u900f\u660e\u80cc\u666f\u65f6\uff0c\u4f1a\u63d0\u793a\u53e6\u5b58\u4e3a, \u8fd9\u4e2a\u60c5\u51b5 EasyIcon \u4e0d\u4f1a\u66f4\u65b0","title":"\u5916\u7f6e\u7f16\u8f91"},{"location":"0051ImageEdit/#_3","text":"","title":"\u5185\u7f6e\u7f16\u8f91"},{"location":"0051ImageEdit/#_4","text":"","title":"\u67e5\u770b"},{"location":"0051ImageEdit/#_5","text":"","title":"\u88c1\u526a"},{"location":"0051ImageEdit/#_6","text":"","title":"\u7f29\u653e"},{"location":"0051ImageEdit/#_7","text":"","titl